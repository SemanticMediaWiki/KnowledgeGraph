{
	"root": true,
	"extends": [
		"wikimedia/client/common",
		"wikimedia/language/es2020",
		"wikimedia/mediawiki"
	],
	"globals": {
		"mw": "readonly",
		"mediaWiki": "readonly",
		"$": "readonly",
		"jQuery": "readonly",
		"vis": "readonly",
		"KnowledgeGraph": "writable",
		"KnowledgeGraphFunctions": "writable",
		"KnowledgeGraphOptions": "writable",
		"KnowledgeGraphDialog": "writable",
		"KnowledgeGraphNonModalDialog": "writable",
		"KnowledgeGraphToolbar": "writable",
		"KnowledgeGraphActionToolbar": "writable",
		"KnowledgeGraphNonContextMenu": "writable"
	},
	"env": {
		"browser": true
	},
	"overrides": [
		{
			"files": [
				"tests/node-qunit/**/*.js"
			],
			"extends": [
				"wikimedia/mediawiki/qunit"
			],
			"env": {
				"node": true
			},
			"rules": {
				"mediawiki/valid-package-file-require": "off"
			}
		}
	]
}
